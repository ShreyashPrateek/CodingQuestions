class Solution {
    public String[] findRelativeRanks(int[] score) 
    {
        // Get the number of scores and initialize the result array
        int n = score.length;
        String[] result = new String[n];

        // Create array of indices
        Integer[] index = new Integer[n]; // Array to hold indices of the scores
        for (int i = 0; i < n; i++) 
        {
            index[i] = i;
        }

        // Sort indices based on scores (descending)
        Arrays.sort(index, (a, b) -> score[b] - score[a]);

        // Assign ranks
        for (int i = 0; i < n; i++) {
            if (i == 0)
                result[index[i]] = "Gold Medal";
            else if (i == 1)
                result[index[i]] = "Silver Medal";
            else if (i == 2)
                result[index[i]] = "Bronze Medal";
            else
                result[index[i]] = String.valueOf(i + 1);
        }

        return result;
    }
}